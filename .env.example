# --- WarpWallet configuration -------------------------------------------------
# Copy to .env.local for local development. All values are optional: with none
# set, the app runs in self-contained DEMO mode (in-memory ledger + faucet) so
# it deploys to Vercel and works out of the box.

# URL of a WarpCoin full-node JSON-RPC endpoint (see kevinsegal/Warpcoin).
# When set, balances, account nonces and transaction broadcast are proxied to
# the real chain instead of the demo ledger.
# WARP_RPC_URL=http://127.0.0.1:8339

# Public base URL of this deployment, used to build merchant checkout links.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional Vercel KV (Upstash Redis) credentials. When present, shared state
# (warp#tags, escrows, merchants, invoices, deployed contracts) is persisted
# across serverless invocations. Without them, shared state is in-memory and
# resets when the serverless instance recycles.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Secret used to sign merchant webhook payloads (HMAC-SHA256). Generate with
# `openssl rand -hex 32`.
# WARP_WEBHOOK_SECRET=
